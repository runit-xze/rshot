{
    "app-id": "org.shutter_project.Shutter",
    "runtime": "org.gnome.Platform",
    "runtime-version": "45",
    "sdk": "org.gnome.Sdk",
    "command": "shutter",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--filesystem=home",
        "--talk-name=org.freedesktop.Notifications"
    ],
    "modules": [
        {
            "name": "shutter",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin /app/share",
                "cp -r bin/* /app/bin/",
                "cp -r share/* /app/share/",
                "chmod +x /app/bin/shutter"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
