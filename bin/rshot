use utf8;
use v5.40;
use FindBin '$Bin';

# Install the Gtk3::IconSize::lookup override globally before any drawing code loads.
# rshot's modules live under /usr/share/perl5/Shutter (Debian Perl Policy §2.3)
# when installed via the Debian package, or under share/shutter/perl/ in the source
# tree for `make install` / `carton exec` development.  Both layouts provide the same
# Shutter:: namespace.
use Shutter::App::Compat::Gtk3IconSize;
use Shutter::App::CLI;

# Determine shutter_root
my $shutter_root = undef;
if ($ENV{PAR_TEMP}) {
	$shutter_root = $ENV{PAR_TEMP};
} else {
	$Bin =~ m/(.*)\//;
	$shutter_root = $1;
}
$ENV{'SHUTTER_ROOT'} = $shutter_root;

# Start the application
my $cli = Shutter::App::CLI->new(shutter_root => $shutter_root);
$cli->run;

__END__

=head1 NAME

rshot - Feature-rich Screenshot Tool

=head1 SYNOPSIS

rshot [options]

=head1 DESCRIPTION

rshot is a feature-rich screenshot program. This is the modular entry point.

=head1 OPTIONS

=over 8

=item B<--debug>

Prints a lot of debugging information to STDOUT (sets log-level to debug).

=item B<--log-file=FILE>

Log output to a file.

=item B<--log-level=LEVEL>

Set the log level (debug, info, warn, error). Default is info.

=item B<--log-json>

Output logs in JSON format.

=item B<--mock-capture>

Enable "Mock" Capture Mode (uses a static test image instead of actual screen capture).

=back

=cut
