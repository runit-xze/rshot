# EditorConfig is a file format for defining coding styles and settings in projects.
# See https://editorconfig.org for more details.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Perl files (source and tests)
[*.{pl,pm,t}]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
indent_style = space
indent_size = 2
