# debhelper runtime artifacts (regenerated on every build)
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/rshot.postinst.debhelper
debian/rshot.postrm.debhelper

# Built manpage (regenerated by debian/rules on every build)
debian/manpages/

# Phase 2 build outputs (in parent dir, never tracked)
*.buildinfo
*.changes
*.deb
